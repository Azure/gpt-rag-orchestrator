AGENT_STRATEGY=single_agent_rag

# AI Foundry / Azure AI Services (Cognitive Services)
AI_FOUNDRY_ACCOUNT_ENDPOINT=https://aif-<uniqueSuffix>.cognitiveservices.azure.com/
AI_FOUNDRY_ACCOUNT_NAME=aif-<uniqueSuffix>
AI_FOUNDRY_ACCOUNT_RESOURCE_ID=/subscriptions/<subscriptionId>/resourceGroups/<resourceGroupName>/providers/Microsoft.CognitiveServices/accounts/aif-<uniqueSuffix>

# AI Foundry Project
AI_FOUNDRY_PROJECT_ENDPOINT=https://aif-<uniqueSuffix>.services.ai.azure.com/api/projects/<projectName>
AI_FOUNDRY_PROJECT_NAME=aifp-<uniqueSuffix>
AI_FOUNDRY_PROJECT_RESOURCE_ID=/subscriptions/<subscriptionId>/resourceGroups/<resourceGroupName>/providers/Microsoft.CognitiveServices/accounts/aif-<uniqueSuffix>/projects/<projectName>

# Storage used by AI Foundry (example naming convention)
AI_FOUNDRY_STORAGE_ACCOUNT_NAME=staif<uniqueSuffix>

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<appInsightsInstrumentationKey>;IngestionEndpoint=https://<region>-1.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/;ApplicationId=<appInsightsApplicationId>
APPLICATIONINSIGHTS__INSTRUMENTATIONKEY=<appInsightsInstrumentationKey>

# App Configuration / App Insights resource names
APP_CONFIG_NAME=appcs-<uniqueSuffix>
APP_INSIGHTS_NAME=appi-<uniqueSuffix>
APP_INSIGHTS_RESOURCE_ID=/subscriptions/<subscriptionId>/resourceGroups/<resourceGroupName>/providers/Microsoft.Insights/components/appi-<uniqueSuffix>

# Azure env basics
AZURE_RESOURCE_GROUP=<resourceGroupName>
AZURE_TENANT_ID=<tenantId>
SUBSCRIPTION_ID=<subscriptionId>

# Optional: Bing / search connector id (if used)
BING_CONNECTION_ID=

# Model deployment names (logical)
CHAT_DEPLOYMENT_NAME=chat

# Container Apps (JSON blob) — keep shape, generalize values
CONTAINER_APPS=[{"name":"ca-<uniqueSuffix>-orchestrator","serviceName":"orchestrator","canonical_name":"ORCHESTRATOR_APP","principalId":"<principalId-guid>","fqdn":"ca-<uniqueSuffix>-orchestrator.<environmentHash>.<region>.azurecontainerapps.io"},{"name":"ca-<uniqueSuffix>-frontend","serviceName":"frontend","canonical_name":"FRONTEND_APP","principalId":"<principalId-guid>","fqdn":"ca-<uniqueSuffix>-frontend.<environmentHash>.<region>.azurecontainerapps.io"},{"name":"ca-<uniqueSuffix>-dataingest","serviceName":"dataingest","canonical_name":"DATA_INGEST_APP","principalId":"<principalId-guid>","fqdn":"ca-<uniqueSuffix>-dataingest.<environmentHash>.<region>.azurecontainerapps.io"},{"name":"ca-<uniqueSuffix>-mcp","serviceName":"mcp","canonical_name":"MCP_APP","principalId":"<principalId-guid>","fqdn":"ca-<uniqueSuffix>-mcp.<environmentHash>.<region>.azurecontainerapps.io"}]

CONTAINER_ENV_NAME=cae-<uniqueSuffix>
CONTAINER_ENV_PRINCIPAL_ID=<principalId-guid>
CONTAINER_ENV_RESOURCE_ID=/subscriptions/<subscriptionId>/resourceGroups/<resourceGroupName>/providers/Microsoft.App/managedEnvironments/cae-<uniqueSuffix>

# Container Registry
CONTAINER_REGISTRY_LOGIN_SERVER=cr<uniqueSuffix>.azurecr.io
CONTAINER_REGISTRY_NAME=cr<uniqueSuffix>

# Cosmos DB
CONVERSATIONS_DATABASE_CONTAINER=conversations
DATASOURCES_DATABASE_CONTAINER=datasources
DATABASE_ACCOUNT_NAME=cosmos-<uniqueSuffix>
DATABASE_NAME=cosmos-db<uniqueSuffix>
COSMOS_DB_ACCOUNT_RESOURCE_ID=/subscriptions/<subscriptionId>/resourceGroups/<resourceGroupName>/providers/Microsoft.DocumentDB/databaseAccounts/cosmos-<uniqueSuffix>
COSMOS_DB_ENDPOINT=https://cosmos-<uniqueSuffix>.documents.azure.com:443/

# Schedules
CRON_RUN_BLOB_INDEX=10 * * * *
CRON_RUN_BLOB_PURGE=0 * * * *

# Container App endpoints / names
DATA_INGEST_APP_ENDPOINT=https://ca-<uniqueSuffix>-dataingest.<environmentHash>.<region>.azurecontainerapps.io
DATA_INGEST_APP_NAME=ca-<uniqueSuffix>-dataingest

FRONTEND_APP_ENDPOINT=https://ca-<uniqueSuffix>-frontend.<environmentHash>.<region>.azurecontainerapps.io
FRONTEND_APP_NAME=ca-<uniqueSuffix>-frontend

ORCHESTRATOR_APP_ENDPOINT=https://ca-<uniqueSuffix>-orchestrator.<environmentHash>.<region>.azurecontainerapps.io
ORCHESTRATOR_APP_NAME=ca-<uniqueSuffix>-orchestrator

MCP_APP_ENDPOINT=https://ca-<uniqueSuffix>-mcp.<environmentHash>.<region>.azurecontainerapps.io
MCP_APP_NAME=ca-<uniqueSuffix>-mcp
MCP_CONTAINER=mcp

# Deployment toggles / metadata
DEPLOYMENT_NAME=<envName>-<epochSecondsOrBuildId>
DEPLOY_APP_CONFIG=True
DEPLOY_APP_INSIGHTS=True
DEPLOY_CONTAINER_APPS=True
DEPLOY_CONTAINER_ENV=True
DEPLOY_CONTAINER_REGISTRY=True
DEPLOY_COSMOS_DB=True
DEPLOY_KEY_VAULT=True
DEPLOY_LOG_ANALYTICS=True
DEPLOY_SEARCH_SERVICE=True
DEPLOY_STORAGE_ACCOUNT=True

ENVIRONMENT_NAME=<envName>
RESOURCE_TOKEN=<uniqueSuffix>

# Storage
STORAGE_ACCOUNT_NAME=st<uniqueSuffix>
STORAGE_ACCOUNT_RESOURCE_ID=/subscriptions/<subscriptionId>/resourceGroups/<resourceGroupName>/providers/Microsoft.Storage/storageAccounts/st<uniqueSuffix>
STORAGE_BLOB_ENDPOINT=https://st<uniqueSuffix>.blob.core.windows.net/
DOCUMENTS_STORAGE_CONTAINER=documents
DOCUMENTS_IMAGES_STORAGE_CONTAINER=documents-images
PROMPTS_CONTAINER=prompts
NL2SQL_STORAGE_CONTAINER=nl2sql

# Models / embeddings
GPT_MODEL_NAME=gpt-4o
GPT_MODEL_DEPLOYMENT_NAME=chat
EMBEDDING_DEPLOYMENT_NAME=text-embedding
EMBEDDINGS_VECTOR_DIMENSIONS=3072

# Optional flags
ENABLE_AGENTIC_RETRIEVAL=false
ENABLE_CONSOLE_LOGGING=true
PROMPT_SOURCE=file
LOG_LEVEL=INFO
NETWORK_ISOLATION=false
USE_UAI=False

# Key Vault
KEY_VAULT_RESOURCE_ID=/subscriptions/<subscriptionId>/resourceGroups/<resourceGroupName>/providers/Microsoft.KeyVault/vaults/kv-<uniqueSuffix>
KEY_VAULT_URI=https://kv-<uniqueSuffix>.vault.azure.net/

# Log Analytics
LOG_ANALYTICS_RESOURCE_ID=/subscriptions/<subscriptionId>/resourceGroups/<resourceGroupName>/providers/Microsoft.OperationalInsights/workspaces/log-<uniqueSuffix>

# Search (Azure AI Search / connections / indexes)
SEARCH_ANALYZER_NAME=standard.lucene
SEARCH_API_VERSION=2025-05-01-preview
SEARCH_SERVICE_NAME=srch-<uniqueSuffix>
SEARCH_SERVICE_PRINCIPAL_ID=<principalId-guid>
SEARCH_SERVICE_QUERY_ENDPOINT=https://srch-<uniqueSuffix>.search.windows.net
SEARCH_SERVICE_RESOURCE_ID=/subscriptions/<subscriptionId>/resourceGroups/<resourceGroupName>/providers/Microsoft.Search/searchServices/srch-<uniqueSuffix>
SEARCH_SERVICE_UAI_RESOURCE_ID=

SEARCH_CONNECTION_ID=/subscriptions/<subscriptionId>/resourceGroups/<resourceGroupName>/providers/Microsoft.CognitiveServices/accounts/aif-<uniqueSuffix>/projects/<projectName>/connections/srch-<uniqueSuffix>-connection

SEARCH_RAG_INDEX_NAME=ragindex-<uniqueSuffix>
SEARCH_MEASURES_INDEX_NAME=nl2sql-<uniqueSuffix>-measures
SEARCH_QUERIES_INDEX_NAME=nl2sql-<uniqueSuffix>-queries
SEARCH_TABLES_INDEX_NAME=nl2sql-<uniqueSuffix>-tables

# Model deployments (JSON blob) — keep shape, generalize values
MODEL_DEPLOYMENTS=[{"canonical_name":"CHAT_DEPLOYMENT_NAME","capacity":40,"model":"gpt-4o","modelFormat":"OpenAI","name":"chat","version":"<modelVersion>","apiVersion":"<apiVersion>","endpoint":"https://aif-<uniqueSuffix>.openai.azure.com/"},{"canonical_name":"EMBEDDING_DEPLOYMENT_NAME","capacity":40,"model":"text-embedding-3-large","modelFormat":"OpenAI","name":"text-embedding","version":"<modelVersion>","apiVersion":"<apiVersion>","endpoint":"https://aif-<uniqueSuffix>.openai.azure.com/"}]

# Region
LOCATION=<region>
